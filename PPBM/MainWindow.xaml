<Window x:Class="PPBM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PPBM.ViewModels"
        xmlns:conv="clr-namespace:PPBM.Converters"
        Title="PPBM"
        Width="980" Height="720"
        MinWidth="780" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <!-- Converters -->
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:RecommendBgConverter x:Key="RecommendBg"/>
        <conv:WarnColorConverter x:Key="WarnColor"/>

        <!-- Colors -->
        <SolidColorBrush x:Key="Bg" Color="#1E1E2E"/>
        <SolidColorBrush x:Key="CardBg" Color="#2A2A3C"/>
        <SolidColorBrush x:Key="CardHover" Color="#333352"/>
        <SolidColorBrush x:Key="Surface" Color="#313244"/>
        <SolidColorBrush x:Key="Text" Color="#CDD6F4"/>
        <SolidColorBrush x:Key="Subtext" Color="#9399B2"/>
        <SolidColorBrush x:Key="Muted" Color="#585B70"/>
        <SolidColorBrush x:Key="Accent" Color="#89B4FA"/>
        <SolidColorBrush x:Key="Green" Color="#A6E3A1"/>
        <SolidColorBrush x:Key="Red" Color="#F38BA8"/>
        <SolidColorBrush x:Key="Yellow" Color="#F9E2AF"/>
        <SolidColorBrush x:Key="Peach" Color="#FAB387"/>
        <SolidColorBrush x:Key="Lavender" Color="#B4BEFE"/>
        <SolidColorBrush x:Key="StatusBarBg" Color="#181825"/>

        <!-- Button Styles -->
        <Style x:Key="AccentBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{StaticResource Accent}"
                                CornerRadius="10" Padding="16,10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#74C7EC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#89DCEB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#585B70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource AccentBtn}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{StaticResource Red}"
                                CornerRadius="10" Padding="16,10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E06C8A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D95B79"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource Subtext}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="Transparent"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource Surface}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource Subtext}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="{StaticResource Surface}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="10,5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource Muted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Checkbox Style -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <!-- Root border with rounded corners and shadow -->
    <Border Background="{StaticResource Bg}" CornerRadius="14">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="4" Opacity="0.4" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ===== TITLE BAR ===== -->
            <Grid Grid.Row="0" Height="48" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0,0,0">
                    <TextBlock Text="PPBM" FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource Accent}" VerticalAlignment="Center"/>
                    <TextBlock Text="·" FontSize="14" Foreground="{StaticResource Muted}"
                               VerticalAlignment="Center" Margin="6,0"/>
                    <TextBlock Text="Processor Boost Manager" FontSize="12"
                               Foreground="{StaticResource Subtext}" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,4,0">
                    <Button Content="─" Style="{StaticResource GhostBtn}"
                            Click="Minimize_Click" Width="40" Height="32"
                            FontSize="16" ToolTip="Minimize"/>
                    <Button Content="□" Style="{StaticResource GhostBtn}"
                            Click="Maximize_Click" Width="40" Height="32"
                            FontSize="14" ToolTip="Maximize"/>
                    <Button x:Name="CloseBtn" Content="✕" Style="{StaticResource GhostBtn}"
                            Click="Close_Click" Width="40" Height="32"
                            FontSize="14" ToolTip="Close"/>
                </StackPanel>
            </Grid>

            <!-- ===== MAIN CONTENT ===== -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24,8,24,8">

                    <!-- CPU TEMP HERO -->
                    <Border Background="{StaticResource CardBg}" CornerRadius="14" Padding="24,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Big temp display -->
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,24,0">
                                <TextBlock Text="CPU" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource Subtext}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding CoreTempDisplay}"
                                           FontSize="64" FontWeight="Light"
                                           Foreground="{Binding TempColorBrush}"
                                           FontFamily="Segoe UI Light"
                                           LineStackingStrategy="BlockLineHeight" LineHeight="64"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="Max core:" FontSize="12"
                                               Foreground="{StaticResource Subtext}"/>
                                    <TextBlock Text="{Binding MaxCoreTemp, StringFormat={}{0:F0}°C}"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource Text}" Margin="4,0,0,0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="Package:" FontSize="12"
                                               Foreground="{StaticResource Subtext}"/>
                                    <TextBlock Text="{Binding PackageTemp, StringFormat={}{0:F0}°C}"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource Text}" Margin="4,0,0,0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="Load:" FontSize="12"
                                               Foreground="{StaticResource Subtext}"/>
                                    <TextBlock Text="{Binding CpuLoad, StringFormat={}{0:F1}%}"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource Text}" Margin="4,0,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Divider -->
                            <Border Grid.Column="1" Width="1" Background="{StaticResource Muted}"
                                    VerticalAlignment="Stretch" Margin="0,8"/>

                            <!-- CPU + Boost Info -->
                            <StackPanel Grid.Column="1" Margin="24,0,24,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding CpuName}" FontSize="17" FontWeight="SemiBold"
                                           Foreground="{StaticResource Text}" TextTrimming="CharacterEllipsis"/>

                                <Border Background="{StaticResource Surface}" CornerRadius="8"
                                        Padding="14,12" Margin="0,12,0,0">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="10" Height="10" Margin="0,0,8,0"
                                                     VerticalAlignment="Center"
                                                     Fill="{Binding DataContext.BoostModeBrush, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                            <TextBlock Text="Boost Mode" FontSize="12"
                                                       Foreground="{StaticResource Subtext}"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding BoostModeName}" FontSize="15"
                                                   FontWeight="SemiBold" Foreground="{StaticResource Text}"
                                                   Margin="0,4,0,0"/>
                                        <TextBlock Text="{Binding BoostHexValue}" FontSize="11"
                                                   Foreground="{StaticResource Muted}"
                                                   FontFamily="Cascadia Code, Consolas, monospace"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Aggressive Warning -->
                                <Border Background="#2A1A2E" CornerRadius="8" Padding="14,10"
                                        Margin="0,10,0,0"
                                        Visibility="{Binding IsAggressiveDetected, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="🚨 Aggressive boost mode is burning your CPU at idle. Fix it now."
                                               Foreground="{StaticResource Red}" FontSize="13"
                                               FontWeight="SemiBold" TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>

                            <!-- Actions column -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Width="180">
                                <Button Content="Auto-Detect &amp; Fix" Style="{StaticResource DangerBtn}"
                                        Command="{Binding AutoFixCommand}"
                                        Visibility="{Binding IsAggressiveDetected, Converter={StaticResource BoolToVis}}"
                                        Margin="0,0,0,8"/>
                                <Button Content="Refresh" Style="{StaticResource AccentBtn}"
                                        Command="{Binding RefreshBoostModeCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- PROFILE CARDS -->
                    <TextBlock Text="Power Profiles" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource Text}" Margin="6,24,0,10"/>

                    <ItemsControl ItemsSource="{Binding Profiles}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="ProfileCard"
                                        Background="{Binding IsRecommended, Converter={StaticResource RecommendBg}}"
                                        CornerRadius="12" Padding="18,14" Margin="0,0,0,8"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="ProfileCard_Click"
                                        Tag="{Binding}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="16" Height="16" Stroke="#585B70" StrokeThickness="2"
                                                         VerticalAlignment="Center">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="Transparent"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="Fill" Value="{StaticResource Accent}"/>
                                                                    <Setter Property="Stroke" Value="{StaticResource Accent}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock Text="{Binding Name}" FontSize="15"
                                                           FontWeight="SemiBold" Foreground="{StaticResource Text}"
                                                           Margin="10,0,0,0"/>
                                                <Border Background="{StaticResource Green}" CornerRadius="4"
                                                        Padding="6,2" Margin="10,0,0,0"
                                                        Visibility="{Binding IsRecommended, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="RECOMMENDED" FontSize="9"
                                                               FontWeight="Bold" Foreground="{StaticResource Bg}"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Description}" FontSize="12"
                                                       Foreground="{StaticResource Subtext}"
                                                       TextWrapping="Wrap" Margin="0,4,0,0"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="{Binding UseCase}" FontSize="11"
                                                           Foreground="{StaticResource Lavender}"/>
                                                <TextBlock Text=" · " FontSize="11"
                                                           Foreground="{StaticResource Muted}"/>
                                                <TextBlock Text="Temps:" FontSize="11"
                                                           Foreground="{StaticResource Subtext}"/>
                                                <TextBlock Text="{Binding TempLabel}" FontSize="11"
                                                           Foreground="{StaticResource Peach}" Margin="4,0,0,0"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <Button Grid.Column="1" Content="Apply" Style="{StaticResource AccentBtn}"
                                                VerticalAlignment="Center" Margin="12,0,0,0"
                                                Tag="{Binding}"
                                                Click="ApplyButton_Click"/>
                                    </Grid>
                                </Border>

                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsRecommended}" Value="True">
                                        <Setter TargetName="ProfileCard" Property="Background" Value="{StaticResource CardHover}"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Max CPU Slider -->
                    <Border Background="{StaticResource CardBg}" CornerRadius="12"
                            Padding="18,14" Margin="0,10,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <CheckBox x:Name="MaxCpuCheck" IsChecked="{Binding MaxCpuEnabled}"
                                          VerticalAlignment="Center" Content="Limit Max CPU Frequency"
                                          FontWeight="SemiBold" FontSize="13"/>
                            </StackPanel>
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Slider Grid.Column="0" Minimum="50" Maximum="100" TickFrequency="5"
                                        Value="{Binding MaxCpuPercent}"
                                        IsSnapToTickEnabled="True"
                                        IsEnabled="{Binding MaxCpuEnabled}"
                                        VerticalAlignment="Center"/>
                                <Border Grid.Column="1" Background="{StaticResource Surface}"
                                        CornerRadius="6" Padding="10,4" Margin="12,0,0,0"
                                        MinWidth="42">
                                    <TextBlock Text="{Binding MaxCpuPercent, StringFormat={}{0}%}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource Text}"
                                               HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <TextBlock Text="Lower values reduce heat at the cost of peak performance. 99% disables turbo boost."
                                       FontSize="11" Foreground="{StaticResource Muted}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- MONITORS -->
                    <TextBlock Text="Connected Monitors" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource Text}" Margin="6,20,0,8"/>

                    <ItemsControl ItemsSource="{Binding Monitors}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource CardBg}" CornerRadius="10"
                                        Padding="14,10" Margin="0,0,8,8" MinWidth="200">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Text}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <TextBlock Text="{Binding CurrentRefreshRate, StringFormat={}{0}Hz}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Subtext}"/>
                                            <TextBlock Text="{Binding RefreshWarning}" FontSize="12"
                                                       Foreground="{Binding IsAbove60Hz, Converter={StaticResource WarnColor}}"
                                                       Margin="8,0,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="High refresh rates on external monitors keep the iGPU busy, adding ~5°C per monitor above 60Hz."
                               FontSize="11" Foreground="{StaticResource Muted}" Margin="8,0,0,0" TextWrapping="Wrap"/>

                    <!-- UTILITIES -->
                    <TextBlock Text="Utilities" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource Text}" Margin="6,20,0,8"/>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Unhide Setting in Windows UI" Style="{StaticResource SmallBtn}"
                                Command="{Binding UnhideCommand}" Margin="0,0,8,0"/>
                        <Button Content="{Binding SurviveButtonText}" Style="{StaticResource SmallBtn}"
                                Command="{Binding ToggleSurviveUpdatesCommand}"/>
                    </StackPanel>

                    <TextBlock Text="Unhide makes the setting appear in Control Panel → Power Options → Advanced. Survive Updates creates a scheduled task to re-apply settings after Windows feature updates."
                               FontSize="11" Foreground="{StaticResource Muted}"
                               Margin="8,4,0,16" TextWrapping="Wrap"/>

                </StackPanel>
            </ScrollViewer>

            <!-- ===== STATUS BAR ===== -->
            <Border Grid.Row="2" Background="{StaticResource StatusBarBg}"
                    CornerRadius="0,0,14,14" Padding="16,8">
                <Grid>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                               Foreground="{StaticResource Subtext}" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="PPBM v1.0 · Run as Administrator" FontSize="11"
                                   Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
