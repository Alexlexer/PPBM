<Window x:Class="PPBM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PPBM.ViewModels"
        xmlns:models="clr-namespace:PPBM.Models"
        xmlns:conv="clr-namespace:PPBM.Converters"
        Title="PPBM"
        Width="1020" Height="720"
        MinWidth="820" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#111111">

    <Window.Resources>
        <!-- ===== CONVERTERS ===== -->
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:RecommendBgConverter x:Key="RecommendBg"/>
        <conv:WarnColorConverter x:Key="WarnColor"/>

        <!-- ===== DESIGN TOKENS: Monochrome Dark Palette ===== -->
        <SolidColorBrush x:Key="TitlebarBg" Color="#0e0e0e"/>
        <SolidColorBrush x:Key="ShellBg" Color="#161616"/>
        <SolidColorBrush x:Key="NavBg" Color="#191919"/>
        <SolidColorBrush x:Key="LayerBg" Color="#1e1e1e"/>
        <SolidColorBrush x:Key="LayerHover" Color="#2a2a2a"/>
        <SolidColorBrush x:Key="StrokeDefault" Color="#2e2e2e"/>
        <SolidColorBrush x:Key="Stroke2" Color="#3a3a3a"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#f0f0f0"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#a0a0a0"/>
        <SolidColorBrush x:Key="TextTertiary" Color="#606060"/>
        <SolidColorBrush x:Key="TextDisabled" Color="#404040"/>
        <SolidColorBrush x:Key="AccentBg" Color="#12FFFFFF"/>
        <SolidColorBrush x:Key="AccentBgHover" Color="#1DFFFFFF"/>
        <SolidColorBrush x:Key="StatusBarBg" Color="#161616"/>
        <SolidColorBrush x:Key="StatusBarBorder" Color="#2a2a2a"/>
        <SolidColorBrush x:Key="NavItemActiveBg" Color="#14FFFFFF"/>
        <SolidColorBrush x:Key="NavItemHoverBg" Color="#0FFFFFFF"/>
        <SolidColorBrush x:Key="ProfileSelectedBg" Color="#0AFFFFFF"/>
        <SolidColorBrush x:Key="ProfileSelectedBorder" Color="#1FFFFFFF"/>
        <SolidColorBrush x:Key="ProfileRecommendedBorder" Color="#14FFFFFF"/>
        <SolidColorBrush x:Key="BadgeBg" Color="#0FFFFFFF"/>
        <SolidColorBrush x:Key="BadgeBorder" Color="#1FFFFFFF"/>
        <SolidColorBrush x:Key="BadgeText" Color="#c0c0c0"/>
        <SolidColorBrush x:Key="BadgeHotBg" Color="#0AFFFFFF"/>
        <SolidColorBrush x:Key="BadgeHotBorder" Color="#14FFFFFF"/>
        <SolidColorBrush x:Key="BadgeHotText" Color="#707070"/>
        <SolidColorBrush x:Key="SliderFill" Color="#d0d0d0"/>
        <SolidColorBrush x:Key="AccentBtnBg" Color="#12FFFFFF"/>
        <SolidColorBrush x:Key="AccentBtnBorder" Color="#20FFFFFF"/>
        <SolidColorBrush x:Key="DangerBtnBg" Color="#0FFFFFFF"/>
        <SolidColorBrush x:Key="DangerBtnBorder" Color="#20FFFFFF"/>
        <SolidColorBrush x:Key="GhostBtnBg" Color="#0CFFFFFF"/>
        <SolidColorBrush x:Key="GhostBtnBorder" Color="#2e2e2e"/>
        <SolidColorBrush x:Key="GhostBtnHover" Color="#17FFFFFF"/>
        <SolidColorBrush x:Key="AlertBannerBg" Color="#0AFFFFFF"/>
        <SolidColorBrush x:Key="AlertBannerBorder" Color="#1AFFFFFF"/>
        <SolidColorBrush x:Key="ToggleThumbOff" Color="#606060"/>
        <SolidColorBrush x:Key="ToggleThumbOn" Color="#f0f0f0"/>
        <SolidColorBrush x:Key="ToggleTrackOff" Color="#3a3a3a"/>
        <SolidColorBrush x:Key="ToggleTrackOn" Color="#40FFFFFF"/>
        <SolidColorBrush x:Key="SettingIconBg" Color="#0CFFFFFF"/>
        <SolidColorBrush x:Key="UtilityIconBg" Color="#0CFFFFFF"/>
        <SolidColorBrush x:Key="UtilityIconBg2" Color="#0AFFFFFF"/>

        <FontFamily x:Key="AppFont">Segoe UI Variable, Segoe UI, sans-serif</FontFamily>
        <FontFamily x:Key="IconFont">Segoe Fluent Icons, Segoe MDL2 Assets</FontFamily>
        <FontFamily x:Key="MonoFont">Cascadia Code, Consolas, monospace</FontFamily>

        <!-- ===== NAV ITEM TEMPLATE ===== -->
        <DataTemplate x:Key="NavItemTemplate" DataType="{x:Type models:NavItem}">
            <Button Cursor="Hand"
                    Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding PageName}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="indicator"
                                    Width="3" Height="18" Background="{StaticResource TextPrimary}"
                                    CornerRadius="0,2,2,0" HorizontalAlignment="Left"
                                    VerticalAlignment="Center" Margin="2,0,0,0"
                                    Visibility="Collapsed"/>
                            <Border x:Name="bg"
                                    Background="Transparent" CornerRadius="6"
                                    Padding="10,8" Margin="6,1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding IconGlyph}"
                                               FontFamily="{StaticResource IconFont}"
                                               FontSize="16"
                                               Foreground="{StaticResource TextSecondary}"
                                               Width="20" TextAlignment="Center"
                                               VerticalAlignment="Center"
                                               x:Name="icon"/>
                                    <TextBlock Text="{Binding Label}"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="13" FontWeight="Normal"
                                               Foreground="{StaticResource TextSecondary}"
                                               VerticalAlignment="Center" Margin="14,0,0,0"
                                               x:Name="label"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{StaticResource NavItemHoverBg}"/>
                                <Setter TargetName="icon" Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                <Setter TargetName="label" Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter TargetName="indicator" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="bg" Property="Background" Value="{StaticResource NavItemActiveBg}"/>
                                <Setter TargetName="icon" Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                <Setter TargetName="label" Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                <Setter TargetName="label" Property="FontWeight" Value="SemiBold"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </DataTemplate>

        <!-- ===== ACCENT BUTTON STYLE ===== -->
        <Style x:Key="AccentBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{StaticResource AccentBtnBg}"
                                BorderBrush="{StaticResource AccentBtnBorder}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentBgHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#08FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource TextDisabled}"/>
                                <Setter TargetName="border" Property="Background" Value="Transparent"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== DANGER BUTTON STYLE ===== -->
        <Style x:Key="DangerBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{StaticResource DangerBtnBg}"
                                BorderBrush="{StaticResource DangerBtnBorder}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#28FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="Transparent"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== GHOST BUTTON STYLE ===== -->
        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Background" Value="{StaticResource GhostBtnBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource GhostBtnBorder}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6" Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource GhostBtnHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== TITLE BAR BUTTON STYLE ===== -->
        <Style x:Key="TitleBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontFamily" Value="{StaticResource IconFont}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#14FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== PROFILE ITEM DATA TEMPLATE ===== -->
        <DataTemplate DataType="{x:Type models:PowerProfile}">
            <Border x:Name="card"
                    Background="{StaticResource LayerBg}"
                    BorderBrush="{StaticResource StrokeDefault}"
                    BorderThickness="1"
                    CornerRadius="8" Padding="14,12" Margin="0,0,0,2"
                    Cursor="Hand"
                    MouseLeftButtonDown="ProfileCard_Click"
                    Tag="{Binding}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Radio circle -->
                    <Ellipse Grid.Column="0" x:Name="radio" Width="18" Height="18"
                             Stroke="{StaticResource Stroke2}" StrokeThickness="2"
                             VerticalAlignment="Center"/>
                    <Ellipse Grid.Column="0" x:Name="radioFill" Width="18" Height="18"
                             Fill="{StaticResource TextPrimary}" VerticalAlignment="Center"
                             Visibility="Collapsed"/>
                    <Ellipse Grid.Column="0" x:Name="radioDot" Width="6" Height="6"
                             Fill="#111111" VerticalAlignment="Center"
                             Visibility="Collapsed"/>

                    <!-- Body -->
                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Name}"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <!-- RECOMMENDED badge -->
                            <Border x:Name="badgeRec" Background="{StaticResource BadgeBg}"
                                    BorderBrush="{StaticResource BadgeBorder}"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="5,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="RECOMMENDED"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource BadgeText}"
                                           TextOptions.TextFormattingMode="Display"/>
                            </Border>
                            <!-- HOT badge -->
                            <Border x:Name="badgeHot" Background="{StaticResource BadgeHotBg}"
                                    BorderBrush="{StaticResource BadgeHotBorder}"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="5,2" Margin="8,0,0,0" VerticalAlignment="Center"
                                    Visibility="Collapsed">
                                <TextBlock Text="HOT"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource BadgeHotText}"
                                           TextOptions.TextFormattingMode="Display"/>
                            </Border>
                            <!-- PERFORMANCE badge -->
                            <Border x:Name="badgePerf" Background="{StaticResource BadgeHotBg}"
                                    BorderBrush="{StaticResource BadgeHotBorder}"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="5,2" Margin="8,0,0,0" VerticalAlignment="Center"
                                    Visibility="Collapsed">
                                <TextBlock Text="PERFORMANCE"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource BadgeHotText}"
                                           TextOptions.TextFormattingMode="Display"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="{Binding Description}"
                                   FontFamily="{StaticResource AppFont}"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondary}"
                                   TextWrapping="Wrap" Margin="0,2,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="{Binding UseCase}"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextTertiary}"/>
                            <TextBlock Text=" · "
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextDisabled}"/>
                            <TextBlock Text="Temps: "
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextTertiary}"/>
                            <TextBlock Text="{Binding TempLabel}"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondary}"
                                       Margin="2,0,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Apply button -->
                    <Button Grid.Column="2"
                            Style="{StaticResource AccentBtn}"
                            Content="Apply"
                            VerticalAlignment="Center" Margin="12,0,0,0"
                            Tag="{Binding}"
                            Click="ApplyButton_Click"/>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsRecommended}" Value="True">
                    <Setter TargetName="card" Property="BorderBrush" Value="{StaticResource ProfileRecommendedBorder}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter TargetName="card" Property="Background" Value="{StaticResource ProfileSelectedBg}"/>
                    <Setter TargetName="card" Property="BorderBrush" Value="{StaticResource ProfileSelectedBorder}"/>
                    <Setter TargetName="radioFill" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="radioDot" Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding BoostMode}" Value="0">
                    <Setter TargetName="badgeRec" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="badgeHot" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="badgePerf" Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding BoostMode}" Value="2">
                    <Setter TargetName="badgeRec" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="badgeHot" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="badgePerf" Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding BoostMode}" Value="3">
                    <Setter TargetName="badgeRec" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="badgeHot" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="badgePerf" Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding BoostMode}" Value="4">
                    <Setter TargetName="badgeRec" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="badgeHot" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="badgePerf" Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding BoostMode}" Value="1">
                    <Setter TargetName="badgeRec" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="badgeHot" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="badgePerf" Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- ===== MONITOR CHIP TEMPLATE ===== -->
        <DataTemplate DataType="{x:Type models:MonitorInfo}">
            <Border x:Name="chip"
                    Background="{StaticResource LayerBg}"
                    BorderBrush="{StaticResource StrokeDefault}"
                    BorderThickness="1"
                    CornerRadius="8" Padding="12,10" MinWidth="180">
                <StackPanel>
                    <TextBlock Text="{Binding Name}"
                               FontFamily="{StaticResource AppFont}"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               TextTrimming="CharacterEllipsis"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,2">
                        <TextBlock Text="{Binding CurrentRefreshRate}"
                                   FontFamily="{StaticResource AppFont}"
                                   FontSize="22" FontWeight="Light"
                                   Foreground="{StaticResource TextPrimary}"
                                   LineStackingStrategy="BlockLineHeight" LineHeight="24"/>
                        <TextBlock Text=" Hz"
                                   FontFamily="{StaticResource AppFont}"
                                   FontSize="13" FontWeight="Normal"
                                   Foreground="{StaticResource TextTertiary}"
                                   VerticalAlignment="Bottom" Margin="2,0,0,3"/>
                    </StackPanel>
                    <TextBlock x:Name="warnText"
                               FontFamily="{StaticResource AppFont}"
                               FontSize="11"
                               Foreground="#888888"
                               Margin="0,2,0,0"/>
                    <TextBlock x:Name="okText"
                               FontFamily="{StaticResource AppFont}"
                               FontSize="11"
                               Foreground="{StaticResource TextTertiary}"
                               Margin="0,2,0,0"
                               Text="Within safe range"/>
                </StackPanel>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsAbove60Hz}" Value="True">
                    <Setter TargetName="chip" Property="BorderBrush" Value="#1AFFFFFF"/>
                    <Setter TargetName="warnText" Property="Text" Value="Above 60Hz · adds ~5°C"/>
                    <Setter TargetName="okText" Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsAbove60Hz}" Value="False">
                    <Setter TargetName="warnText" Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <!-- ===== ROOT BORDER ===== -->
    <Border Background="#111111" CornerRadius="8" x:Name="RootBorder">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="28"/>
            </Grid.RowDefinitions>

            <!-- ============================ TITLE BAR ============================ -->
            <Grid Grid.Row="0" Background="{StaticResource TitlebarBg}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="14,0,0,0">
                    <Border Width="16" Height="16" Background="#e0e0e0"
                            CornerRadius="3" VerticalAlignment="Center"/>
                    <TextBlock Text="PPBM  ·  Processor Performance Boost Mode Manager"
                               FontFamily="{StaticResource AppFont}"
                               FontSize="12" FontWeight="Medium"
                               Foreground="{StaticResource TextSecondary}"
                               VerticalAlignment="Center" Margin="8,0,0,0"
                               TextOptions.TextFormattingMode="Display"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="&#xE921;" Style="{StaticResource TitleBtn}"
                            Click="Minimize_Click" ToolTip="Minimize"/>
                    <Button Content="&#xE922;" Style="{StaticResource TitleBtn}"
                            Click="Maximize_Click" ToolTip="Maximize"/>
                    <Button x:Name="CloseBtn" Content="&#xE8BB;" Style="{StaticResource TitleBtn}"
                            Click="Close_Click" ToolTip="Close"/>
                </StackPanel>
            </Grid>

            <!-- ============================ SHELL ============================ -->
            <Grid Grid.Row="1" Background="{StaticResource ShellBg}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ===== NAVIGATION PANE ===== -->
                <Border Grid.Column="0" Background="{StaticResource NavBg}"
                        BorderBrush="{StaticResource StrokeDefault}"
                        BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Main section -->
                        <StackPanel Grid.Row="0" Margin="0,12,0,0">
                            <TextBlock Text="MAIN"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextTertiary}"
                                       Margin="22,0,0,6"
                                       TextOptions.TextFormattingMode="Display"/>
                            <ItemsControl ItemsSource="{Binding NavigationItems}">
                                <ItemsControl.Resources>
                                    <DataTemplate DataType="{x:Type models:NavItem}">
                                        <Button Cursor="Hand"
                                                Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding PageName}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Grid>
                                                        <Border x:Name="indicator"
                                                                Width="3" Height="18" Background="{StaticResource TextPrimary}"
                                                                CornerRadius="0,2,2,0" HorizontalAlignment="Left"
                                                                VerticalAlignment="Center" Margin="2,0,0,0"
                                                                Visibility="Collapsed"/>
                                                        <Border x:Name="bg"
                                                                Background="Transparent" CornerRadius="6"
                                                                Padding="10,8" Margin="6,1">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding IconGlyph}"
                                                                           FontFamily="{StaticResource IconFont}"
                                                                           FontSize="16"
                                                                           Foreground="{StaticResource TextSecondary}"
                                                                           Width="20" TextAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           x:Name="icon"/>
                                                                <TextBlock Text="{Binding Label}"
                                                                           FontFamily="{StaticResource AppFont}"
                                                                           FontSize="13" FontWeight="Normal"
                                                                           Foreground="{StaticResource TextSecondary}"
                                                                           VerticalAlignment="Center" Margin="14,0,0,0"
                                                                           x:Name="label"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bg" Property="Background" Value="{StaticResource NavItemHoverBg}"/>
                                                            <Setter TargetName="icon" Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                                            <Setter TargetName="label" Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                                        </Trigger>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter TargetName="indicator" Property="Visibility" Value="Visible"/>
                                                            <Setter TargetName="bg" Property="Background" Value="{StaticResource NavItemActiveBg}"/>
                                                            <Setter TargetName="icon" Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                                            <Setter TargetName="label" Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                                            <Setter TargetName="label" Property="FontWeight" Value="SemiBold"/>
                                                        </DataTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.Resources>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Bottom section: About -->
                        <StackPanel Grid.Row="1">
                            <Border BorderBrush="{StaticResource StrokeDefault}"
                                    BorderThickness="0,1,0,0"
                                    Margin="6,8,6,0"/>
                            <Button Cursor="Hand" Margin="6,8,6,6"
                                    Command="{Binding NavigateCommand}"
                                    CommandParameter="About">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Grid>
                                            <Border x:Name="indicator"
                                                    Width="3" Height="18" Background="{StaticResource TextPrimary}"
                                                    CornerRadius="0,2,2,0" HorizontalAlignment="Left"
                                                    VerticalAlignment="Center" Margin="2,0,0,0"
                                                    Visibility="Collapsed"/>
                                            <Border x:Name="bg"
                                                    Background="Transparent" CornerRadius="6"
                                                    Padding="10,8">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE946;"
                                                               FontFamily="{StaticResource IconFont}"
                                                               FontSize="16"
                                                               Foreground="{StaticResource TextSecondary}"
                                                               Width="20" TextAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               x:Name="icon"/>
                                                    <TextBlock Text="About"
                                                               FontFamily="{StaticResource AppFont}"
                                                               FontSize="13" FontWeight="Normal"
                                                               Foreground="{StaticResource TextSecondary}"
                                                               VerticalAlignment="Center" Margin="14,0,0,0"
                                                               x:Name="label"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bg" Property="Background" Value="{StaticResource NavItemHoverBg}"/>
                                                <Setter TargetName="icon" Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                                <Setter TargetName="label" Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ===== CONTENT AREA (page switching via visibility) ===== -->
                <Grid Grid.Column="1">

                    <!-- ── DASHBOARD PAGE ── -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding IsDashboardVisible}">
                        <StackPanel Margin="28,28,28,24">

                            <!-- Page Header -->
                            <TextBlock Text="Dashboard"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="24" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"
                                       Margin="0,0,0,2"
                                       TextOptions.TextFormattingMode="Display"/>
                            <TextBlock Text="System overview and quick actions"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="12"
                                       Foreground="{StaticResource TextTertiary}"
                                       Margin="0,0,0,20"/>

                            <!-- Hero Card -->
                            <Border Background="{StaticResource LayerBg}"
                                    BorderBrush="{StaticResource StrokeDefault}"
                                    BorderThickness="1"
                                    CornerRadius="8" Padding="20,18" Margin="0,0,0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="1"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Temp Block -->
                                    <StackPanel Grid.Column="0" MinWidth="100" Margin="0,0,20,0">
                                        <TextBlock Text="CPU TEMP"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextTertiary}"
                                                   Margin="0,0,0,2"
                                                   TextOptions.TextFormattingMode="Display"/>
                                        <TextBlock Text="{Binding CoreTempDisplay}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="52" FontWeight="Light"
                                                   Foreground="{Binding TempColor}"
                                                   LineStackingStrategy="BlockLineHeight" LineHeight="52"
                                                   TextOptions.TextFormattingMode="Display"/>
                                        <StackPanel Margin="0,8,0,0">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,1">
                                                <TextBlock Text="Max core"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource TextTertiary}"/>
                                                <TextBlock Text="{Binding MaxCoreTemp, StringFormat={}{0:F0}°C}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondary}"
                                                           Margin="6,0,0,0"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                                                <TextBlock Text="Package"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource TextTertiary}"/>
                                                <TextBlock Text="{Binding PackageTemp, StringFormat={}{0:F0}°C}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondary}"
                                                           Margin="6,0,0,0"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                                                <TextBlock Text="Load"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource TextTertiary}"/>
                                                <TextBlock Text="{Binding CpuLoad, StringFormat={}{0:F0}%}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondary}"
                                                           Margin="6,0,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Divider -->
                                    <Border Grid.Column="1" Background="{StaticResource StrokeDefault}"
                                            Margin="0,4"/>

                                    <!-- Info -->
                                    <StackPanel Grid.Column="2" Margin="20,0,20,0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding CpuName}"
                                                   FontFamily="{StaticResource AppFont}"
                                                   FontSize="18" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <Border Background="#0AFFFFFF"
                                                BorderBrush="{StaticResource StrokeDefault}"
                                                BorderThickness="1" CornerRadius="6"
                                                Padding="10,8" Margin="0,10,0,0">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="8" Height="8"
                                                             Fill="{Binding BoostDotColor}"
                                                             VerticalAlignment="Center" Margin="0,0,7,0"/>
                                                    <TextBlock Text="Boost Mode"
                                                               FontFamily="{StaticResource AppFont}"
                                                               FontSize="11"
                                                               Foreground="{StaticResource TextTertiary}"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding BoostModeName}"
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           Margin="0,3,0,0"/>
                                                <TextBlock Text="{Binding BoostHexValue}"
                                                           FontFamily="{StaticResource MonoFont}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource TextTertiary}"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Alert Banner -->
                                        <Border Background="{StaticResource AlertBannerBg}"
                                                BorderBrush="{StaticResource AlertBannerBorder}"
                                                BorderThickness="1"
                                                CornerRadius="6" Padding="10,8"
                                                Margin="0,8,0,0"
                                                Visibility="{Binding IsAggressiveDetected, Converter={StaticResource BoolToVis}}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xEA39;"
                                                           FontFamily="{StaticResource IconFont}"
                                                           FontSize="14"
                                                           Foreground="{StaticResource TextSecondary}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,8,0"/>
                                                <TextBlock Text="Aggressive boost is burning your CPU at idle — apply a fix now."
                                                           FontFamily="{StaticResource AppFont}"
                                                           FontSize="13" FontWeight="Medium"
                                                           Foreground="{StaticResource TextSecondary}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <!-- Actions -->
                                    <StackPanel Grid.Column="3" Width="170" VerticalAlignment="Center">
                                        <Button Content="Auto-Detect &amp; Fix"
                                                Style="{StaticResource DangerBtn}"
                                                Command="{Binding AutoFixCommand}"
                                                Visibility="{Binding IsAggressiveDetected, Converter={StaticResource BoolToVis}}"
                                                Margin="0,0,0,8"/>
                                        <Button Content="Refresh"
                                                Style="{StaticResource AccentBtn}"
                                                Command="{Binding RefreshBoostModeCommand}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Section: Power Profiles -->
                            <TextBlock Text="Power Profiles"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondary}"
                                       Margin="0,20,0,8"
                                       TextOptions.TextFormattingMode="Display"/>

                            <ItemsControl ItemsSource="{Binding Profiles}"
                                          Margin="0,0,0,4"/>

                            <!-- Section: CPU Frequency Cap -->
                            <TextBlock Text="CPU Frequency Cap"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondary}"
                                       Margin="0,18,0,8"
                                       TextOptions.TextFormattingMode="Display"/>

                            <Border Background="{StaticResource LayerBg}"
                                    BorderBrush="{StaticResource StrokeDefault}"
                                    BorderThickness="1"
                                    CornerRadius="8" Padding="14,12">
                                <StackPanel>
                                    <!-- Toggle Row -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="32" Height="32"
                                                Background="{StaticResource SettingIconBg}"
                                                CornerRadius="6"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="&#xE713;"
                                                       FontFamily="{StaticResource IconFont}"
                                                       FontSize="16"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="Limit Max CPU Frequency"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="13" FontWeight="Medium"
                                                       Foreground="{StaticResource TextPrimary}"/>
                                            <TextBlock Text="99% disables turbo boost without restricting base clock"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextTertiary}"
                                                       Margin="0,1,0,0"/>
                                        </StackPanel>
                                        <!-- Toggle Switch -->
                                        <CheckBox Grid.Column="2"
                                                  IsChecked="{Binding MaxCpuEnabled}"
                                                  VerticalAlignment="Center">
                                            <CheckBox.Template>
                                                <ControlTemplate TargetType="CheckBox">
                                                    <Grid Cursor="Hand">
                                                        <Border x:Name="track" Width="40" Height="22"
                                                                CornerRadius="11"
                                                                Background="{StaticResource ToggleTrackOff}"
                                                                BorderBrush="{StaticResource Stroke2}"
                                                                BorderThickness="1"/>
                                                        <Ellipse x:Name="thumb" Width="14" Height="14"
                                                                 Fill="{StaticResource ToggleThumbOff}"
                                                                 HorizontalAlignment="Left"
                                                                 VerticalAlignment="Center"
                                                                 Margin="3,0,0,0"/>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="track" Property="Background" Value="{StaticResource ToggleTrackOn}"/>
                                                            <Setter TargetName="track" Property="BorderBrush" Value="#4DFFFFFF"/>
                                                            <Setter TargetName="thumb" Property="Fill" Value="{StaticResource ToggleThumbOn}"/>
                                                            <Setter TargetName="thumb" Property="Margin" Value="21,0,0,0"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </CheckBox.Template>
                                        </CheckBox>
                                    </Grid>

                                    <!-- Slider Row -->
                                    <Grid Margin="0,4,0,0">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding MaxCpuEnabled}" Value="False">
                                                        <Setter Property="Opacity" Value="0.4"/>
                                                        <Setter Property="IsHitTestVisible" Value="False"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Slider Grid.Column="0" Minimum="50" Maximum="100"
                                                TickFrequency="5" VerticalAlignment="Center"
                                                Value="{Binding MaxCpuPercent}"
                                                Height="4"/>
                                        <Border Grid.Column="1"
                                                Background="#0CFFFFFF"
                                                BorderBrush="{StaticResource StrokeDefault}"
                                                BorderThickness="1"
                                                CornerRadius="5" Padding="6,4"
                                                Margin="12,0,0,0" MinWidth="48">
                                            <TextBlock Text="{Binding MaxCpuPercent, StringFormat={}{0}%}"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       HorizontalAlignment="Center"/>
                                        </Border>
                                    </Grid>

                                    <TextBlock Text="Lower values reduce heat at the cost of peak performance."
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="12"
                                               Foreground="{StaticResource TextTertiary}"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- ── PROFILES PAGE ── -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding IsProfilesVisible}">
                        <StackPanel Margin="28,28,28,24">
                            <TextBlock Text="Power Profiles"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="24" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"
                                       Margin="0,0,0,2"
                                       TextOptions.TextFormattingMode="Display"/>
                            <TextBlock Text="Select a preset to apply the boost mode setting"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="12"
                                       Foreground="{StaticResource TextTertiary}"
                                       Margin="0,0,0,20"/>
                            <ItemsControl ItemsSource="{Binding Profiles}"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ── MONITORS PAGE ── -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding IsMonitorsVisible}">
                        <StackPanel Margin="28,28,28,24">
                            <TextBlock Text="Connected Monitors"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="24" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"
                                       Margin="0,0,0,2"
                                       TextOptions.TextFormattingMode="Display"/>
                            <TextBlock Text="Refresh rate affects iGPU load and CPU thermals"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="12"
                                       Foreground="{StaticResource TextTertiary}"
                                       Margin="0,0,0,20"/>
                            <ItemsControl ItemsSource="{Binding Monitors}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                            <TextBlock Text="High refresh rates on external monitors keep the integrated GPU constantly active, adding approximately 5°C per monitor running above 60 Hz at idle."
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="12"
                                       Foreground="{StaticResource TextTertiary}"
                                       Margin="0,14,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ── UTILITIES PAGE ── -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding IsUtilitiesVisible}">
                        <StackPanel Margin="28,28,28,24">
                            <TextBlock Text="Utilities"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="24" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"
                                       Margin="0,0,0,2"
                                       TextOptions.TextFormattingMode="Display"/>
                            <TextBlock Text="Power setting visibility and persistence tools"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="12"
                                       Foreground="{StaticResource TextTertiary}"
                                       Margin="0,0,0,20"/>

                            <Border Background="{StaticResource LayerBg}"
                                    BorderBrush="{StaticResource StrokeDefault}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <StackPanel>

                                    <!-- Unhide -->
                                    <Grid Background="Transparent" Margin="14,12" Cursor="Hand">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="32" Height="32"
                                                Background="{StaticResource UtilityIconBg}"
                                                CornerRadius="6" VerticalAlignment="Center">
                                            <TextBlock Text="&#xE774;"
                                                       FontFamily="{StaticResource IconFont}"
                                                       FontSize="16"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="Unhide Boost Setting in Windows UI"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="13" FontWeight="Medium"
                                                       Foreground="{StaticResource TextPrimary}"/>
                                            <TextBlock Text="Makes this setting visible in Control Panel → Power Options → Advanced Settings"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextTertiary}"
                                                       Margin="0,1,0,0"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="Run"
                                                Style="{StaticResource GhostBtn}"
                                                Command="{Binding UnhideCommand}"
                                                VerticalAlignment="Center"/>
                                    </Grid>

                                    <Border Background="{StaticResource StrokeDefault}" Height="1"/>

                                    <!-- Survive Updates -->
                                    <Grid Background="Transparent" Margin="14,12" Cursor="Hand">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="32" Height="32"
                                                Background="{StaticResource UtilityIconBg2}"
                                                CornerRadius="6" VerticalAlignment="Center">
                                            <TextBlock Text="&#xE72E;"
                                                       FontFamily="{StaticResource IconFont}"
                                                       FontSize="16"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="Survive Windows Updates"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="13" FontWeight="Medium"
                                                       Foreground="{StaticResource TextPrimary}"/>
                                            <TextBlock Text="Creates a scheduled task that re-applies your settings after feature updates, with a 30-second startup delay"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextTertiary}"
                                                       Margin="0,1,0,0"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="{Binding SurviveButtonText}"
                                                Style="{StaticResource GhostBtn}"
                                                Command="{Binding ToggleSurviveUpdatesCommand}"
                                                VerticalAlignment="Center"/>
                                    </Grid>

                                    <Border Background="{StaticResource StrokeDefault}" Height="1"/>

                                    <!-- Open Debug Log -->
                                    <Grid Background="Transparent" Margin="14,12" Cursor="Hand">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="32" Height="32"
                                                Background="{StaticResource UtilityIconBg2}"
                                                CornerRadius="6" VerticalAlignment="Center">
                                            <TextBlock Text="&#xE8A5;"
                                                       FontFamily="{StaticResource IconFont}"
                                                       FontSize="16"
                                                       Foreground="{StaticResource TextTertiary}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="Open Debug Log"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="13" FontWeight="Medium"
                                                       Foreground="{StaticResource TextPrimary}"/>
                                            <TextBlock Text="%LOCALAPPDATA%\PPBM\debug.log — all powercfg interactions are recorded here"
                                                       FontFamily="{StaticResource AppFont}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextTertiary}"
                                                       Margin="0,1,0,0"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="Open"
                                                Style="{StaticResource GhostBtn}"
                                                Command="{Binding OpenLogCommand}"
                                                VerticalAlignment="Center"/>
                                    </Grid>

                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                </Grid>
            </Grid>

            <!-- ============================ STATUS BAR ============================ -->
            <Border Grid.Row="2"
                    Background="{StaticResource StatusBarBg}"
                    BorderBrush="{StaticResource StatusBarBorder}"
                    BorderThickness="0,1,0,0"
                    Padding="16,0">
                <Grid>
                    <TextBlock Text="{Binding StatusMessage}"
                               FontFamily="{StaticResource AppFont}"
                               FontSize="11"
                               Foreground="{StaticResource TextTertiary}"
                               VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <!-- Boost Status Pill -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                            <Ellipse Width="6" Height="6"
                                     Fill="{Binding BoostStatusDot}"
                                     VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding BoostStatusText}"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextTertiary}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="|"
                                   FontFamily="{StaticResource AppFont}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextDisabled}"
                                   Margin="0,0,14,0"/>
                        <TextBlock Text="PPBM v1.0"
                                   FontFamily="{StaticResource AppFont}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextTertiary}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text=" · "
                                   FontFamily="{StaticResource AppFont}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextDisabled}"/>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6"
                                     Fill="#c0c0c0"
                                     VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Administrator"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextTertiary}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
